# ------------------------------------------------------------------------------
# Backend (Admin Panel) — Environment Variables
# ------------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your environment.
# Only vars prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ------------------------------------------------------------------------------

NODE_ENV="development"

# Public URL of the @api microservice (must include the global /api prefix).
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# Optional: run admin under a sub-folder (e.g. /admin).
# - Empty/unset: serve at root (no basePath).
# - Example prod with nginx subfolder: NEXT_PUBLIC_BACKEND_BASE_PATH=/admin
NEXT_PUBLIC_BACKEND_BASE_PATH=/admin

# Optional: force trailing slashes on all admin routes.
# - true  → /admin/login/  (with trailing slash)
# - false → /admin/login   (without trailing slash)
NEXT_PUBLIC_TRAILING_SLASH=false
