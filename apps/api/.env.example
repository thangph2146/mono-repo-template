# Database Configuration
# Đặt file này thành `.env` tại `apps/api/` hoặc tại thư mục gốc monorepo (`store-sync/.env`).
# Cả hai đều được nạp; `apps/api/.env` ghi đè biến trùng tên.
# Supported types: postgresql, mysql, mssql, mongodb, sqlite
# The driver will be automatically detected from the URL protocol if not specified via DB_CLIENT

NODE_ENV="development"

# Example for PostgreSQL
DATABASE_URL="mysql://root@localhost:3306/storesync"
# DB_CLIENT=postgresql

# Example for MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/storesync
# DB_CLIENT=mysql

# Example for SQL Server
# DATABASE_URL=sqlserver://user:password@localhost:1433/storesync
# DB_CLIENT=mssql

# Example for SQLite
# DATABASE_URL=sqlite://./data.sqlite
# DB_CLIENT=sqlite

# Debugging
# Trong development, SQL query log bật mặc định (NODE_ENV=development).
# Đặt DB_DEBUG=false để tắt khi cần console sạch hơn.
# DB_DEBUG=false

# Application
PORT=3002
SERVICE_NAME=@api

# Optional API prefix:
# - API_PREFIX=api  -> routes as /api/*
# - API_PREFIX=     -> routes at root /*
API_PREFIX=api

# Tuỳ chọn: nếu đặt (khác rỗng), mọi request /api/data-maintenance/* phải gửi header X-Backup-Secret trùng giá trị.
# Để trống = không yêu cầu secret (thường dùng local).
# BACKUP_IMPORT_SECRET=

# RBAC: các route có @Permissions yêu cầu header X-User-Id = id user (sau đăng nhập). Login (/users/login) không cần.

# Comma-separated list of allowed CORS origins for browser clients.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
