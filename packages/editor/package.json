{
  "name": "@lexical-editor",
  "version": "0.0.24",
  "description": "Rich Text Editor library based on Lexical for React/Next.js",
  "license": "MIT",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "@lexical/code": "^0.38.2",
    "@lexical/file": "^0.38.2",
    "@lexical/hashtag": "^0.38.2",
    "@lexical/link": "^0.38.2",
    "@lexical/list": "^0.38.2",
    "@lexical/markdown": "^0.38.2",
    "@lexical/overflow": "^0.38.2",
    "@lexical/rich-text": "^0.38.2",
    "@lexical/selection": "^0.38.2",
    "@lexical/table": "^0.38.2",
    "@lexical/text": "^0.38.2",
    "@lexical/utils": "^0.38.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.4",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.552.0",
    "sonner": "^2.0.7"
  },
  "peerDependencies": {
    "@lexical/react": "^0.38.2",
    "lexical": "^0.38.2",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.39.2",
    "next": "16.1.6",
    "sass": "^1.83.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./editor": {
      "types": "./dist/editor-x/editor.d.ts",
      "import": "./dist/editor-x/editor.js",
      "require": "./dist/editor-x/editor.cjs"
    },
    "./styles": {
      "sass": "./src/themes/editor-theme.scss",
      "default": "./src/themes/editor-theme.scss"
    },
    "./variables": {
      "sass": "./src/themes/_variables.scss",
      "default": "./src/themes/_variables.scss"
    },
    "./themes/*": "./src/themes/*.ts",
    "./utils/*": "./src/utils/*.ts"
  }
}