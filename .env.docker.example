# =============================================================================
# Docker Deployment — Environment Variables
# Copy file này thành .env và sửa giá trị cho phù hợp.
# Docker Compose tự động đọc file .env cùng thư mục.
# =============================================================================

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=storesync
MYSQL_DATABASE=hub_parent
MYSQL_USER=storesync
MYSQL_PASSWORD=storesync
MYSQL_PORT=3306

# ---------------------------------------------------------------------------
# API (NestJS) — Runtime env
# ---------------------------------------------------------------------------
# CORS origins cho browser (comma-separated)
# Production: https://phuhuynh.hub.edu.vn
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# External academic API (HUB proxy)
# EXTERNAL_API_URL=https://parentapi.hub.edu.vn
# EXTERNAL_API_TOKEN=your-token

# Backup import secret (để trống nếu không dùng)
# BACKUP_IMPORT_SECRET=

# ---------------------------------------------------------------------------
# Frontend & Backend — Build-time NEXT_PUBLIC_* (cần rebuild image nếu đổi)
# Các biến này được bake vào bundle JS khi docker build.
# Để override, dùng: docker compose build --build-arg <var>=<value>
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:3002/api
# NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_BACKEND_BASE_PATH=/admin
# NEXT_PUBLIC_TRAILING_SLASH=false
